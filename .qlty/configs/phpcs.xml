<?xml version="1.0"?>
<ruleset name="Project">

    <!-- DisallowMixedTypeHint excluded: this toolkit handles arbitrary user-shaped
         data (filter values, attribute maps, resource JSON), so `mixed` and
         `array<string, mixed>` are correct types, not laziness. Narrowable cases
         were tightened first; PHPStan still guards unsafe mixed access. -->
    <rule ref="SineMaculaLaravelPackage">
        <exclude name="SlevomatCodingStandard.TypeHints.DisallowMixedTypeHint"/>
    </rule>

    <file>src</file>
    <file>tests</file>

</ruleset>
