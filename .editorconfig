root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

[*.md]
indent_size = unset

[*.{yml,yaml}]
indent_size = 2

# Vendored meta-schemas committed byte-for-byte from upstream; their
# indentation is not ours to normalise.
[tests/Fixtures/openapi/*.json]
indent_size = unset
