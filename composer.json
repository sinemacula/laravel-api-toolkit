{
    "name": "sinemacula/laravel-api-toolkit",
    "type": "library",
    "description": "A comprehensive Laravel toolkit for streamlined development of RESTful APIs",
    "keywords": [
        "sine macula",
        "laravel",
        "restful",
        "api",
        "toolkit"
    ],
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "Ben Carey",
            "email": "bdmc@sinemacula.co.uk"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/database": "*",
        "illuminate/http": "*",
        "illuminate/notifications": "*",
        "illuminate/routing": "*",
        "illuminate/support": "^12.9",
        "illuminate/validation": "*",
        "sinemacula/http-primitives-php": "^2.0",
        "sinemacula/laravel-repositories": "^2.0",
        "sinemacula/laravel-resource-exporter": "^2.0"
    },
    "suggest": {
        "aws/aws-sdk-php": "Required for CloudWatch logging (^3.342)",
        "phpnexus/cwh": "Required for CloudWatch logging (^3.0)"
    },
    "require-dev": {
        "aws/aws-sdk-php": "^3.342",
        "brianium/paratest": "^7.20",
        "friendsofphp/php-cs-fixer": "^3.94",
        "infection/infection": "^0.33.2",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^9.0 || ^10.0",
        "phpnexus/cwh": "^3.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpdoc-parser": "^2.3",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-mockery": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^12.5",
        "sinemacula/coding-standards": "^1.0",
        "slevomat/coding-standard": "^8.28",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "SineMacula\\ApiToolkit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "check": [
            "qlty check"
        ],
        "format": [
            "qlty fmt"
        ],
        "smells": [
            "qlty smells"
        ],
        "test": [
            "@php vendor/bin/paratest"
        ],
        "test:coverage": [
            "@php vendor/bin/paratest --coverage-clover=clover.xml"
        ],
        "test:mutation": [
            "@php vendor/bin/infection --configuration=infection.json5 --test-framework-options=\"--do-not-fail-on-warning --do-not-fail-on-phpunit-warning\" --only-covering-test-cases --min-msi=95 --min-covered-msi=95"
        ],
        "test:mutation:full": [
            "@php vendor/bin/infection --configuration=infection.full.json5 --test-framework-options=\"--do-not-fail-on-warning --do-not-fail-on-phpunit-warning\" --only-covering-test-cases"
        ]
    },
    "scripts-descriptions": {
        "check": "Run static analysis and lint checks via qlty.",
        "format": "Format codebase using qlty.",
        "smells": "Report code smells (duplication, complexity) via qlty.",
        "test": "Run the PHPUnit test suite in parallel using Paratest.",
        "test:coverage": "Run the PHPUnit test suite with clover coverage report.",
        "test:mutation": "Run the Infection mutation-testing gate against the MSI thresholds.",
        "test:mutation:full": "Run the full Infection mutation suite without MSI thresholds."
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "infection/extension-installer": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SineMacula\\ApiToolkit\\ApiServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
